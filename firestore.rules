rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email != null && 
             (exists(/databases/$(database)/documents/admins/$(request.auth.token.email)) ||
              request.auth.token.email == 'omerbedirhano@gmail.com');
    }

    function isValidProfile() {
      let data = request.resource.data;
      return data.name is string && data.name.size() >= 2 &&
             data.age is int && data.age >= 18 &&
             data.photoUrls is list && data.photoUrls.size() >= 1;
    }

    // User Profiles
    match /users/{userId} {
      // Everyone who is authenticated can read profiles (Discovery)
      allow read: if isAuthenticated(); 
      
      // Create: Only owner and must be valid
      allow create: if isAuthenticated() && isOwner(userId) && isValidProfile();
      
      // Update: Only owner (without changing UID) OR admin OR modifying followers list OR incrementing reportCount
      allow update: if isAuthenticated() && (
        isOwner(userId) || 
        isAdmin() || 
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers']) &&
          (
            (
              request.resource.data.followers.hasAll(resource.data.get('followers', [])) &&
              resource.data.get('followers', []).hasAll(request.resource.data.followers.removeAll([request.auth.uid]))
            ) || (
              resource.data.get('followers', []).hasAll(request.resource.data.followers) &&
              request.resource.data.followers.hasAll(resource.data.get('followers', []).removeAll([request.auth.uid]))
            )
          )
        ) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reportCount']) &&
          request.resource.data.reportCount == (resource.data.get('reportCount', 0) + 1)
        )
      );
      
      allow delete: if isAuthenticated() && isOwner(userId);
      
      // Swipes (Sub-collection)
      match /swipes/{targetId} {
        allow read: if isAuthenticated(); // Needed for client-side matching check
        allow write: if isAuthenticated() && isOwner(userId);
      }


      // Notifications (Sub-collection)
      match /notifications/{notifId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create: if isAuthenticated(); // Allow others to send notifications (likes/matches)
        allow update: if isAuthenticated() && isOwner(userId); // Mark as read
        allow delete: if isAuthenticated() && isOwner(userId); // Allow user to delete own notifications
      }

      // Likes (Sub-collection) - who liked this user
      match /likes/{likeId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
 
      // Visitors (Sub-collection) - who visited this user's profile
      match /visitors/{visitorId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow write: if isAuthenticated();
      }

      // Stats (Sub-collection) - daily swipe limits, etc.
      match /stats/{statsId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }

      // Blocked Users (Sub-collection)
      match /blocked_users/{blockedUserId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // Matches
    match /matches/{matchId} {
      // Only users involved in the match can read
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.userIds);
      
      // Prevent manual creation of matches by clients to avoid "matching with anyone" hack.
      // Ideally, matches should be created via Cloud Functions.
      // If client-side is required, we must at least ensure the requester is one of the userIds.
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.userIds);
      
      allow update, delete: if false; // Matches are immutable once created
    }

    // Calls (Audio Calling)
    match /calls/{callId} {
      allow create: if isAuthenticated() && request.resource.data.callerId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && (
        (resource != null && (resource.data.callerId == request.auth.uid || resource.data.receiverId == request.auth.uid)) ||
        (request.resource != null && (request.resource.data.callerId == request.auth.uid || request.resource.data.receiverId == request.auth.uid))
      );
    }

    // Conversations
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.userIds);
      
      // Conversation can only be created if user is a participant
      allow create: if isAuthenticated() && 
                    request.resource.data.userIds.size() == 2 &&
                    (request.auth.uid in request.resource.data.userIds);
      
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.userIds);

      // Messages
      match /messages/{messageId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.userIds);
        allow create: if isAuthenticated() && 
                     request.resource.data.senderId == request.auth.uid;
      }

      // Typing Indicators
      match /typing/{typingUserId} {
        allow read: if isAuthenticated() && (request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.userIds);
        allow write: if isAuthenticated() && isOwner(typingUserId);
      }
    }

    // Stories (24h Instagram-like stories)
    match /stories/{storyId} {
      // Everyone can see stories (filtering is done client-side for matches/premium)
      allow read: if isAuthenticated();
      
      // Only the owner can create their own story
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Anyone can update viewers array
      allow update: if isAuthenticated();

      
      // Stories cannot be manually deleted by clients (use TTL or Cloud Function)
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    
    // Spaces (Audio Spaces, Room-like chat spaces)
    match /spaces/{spaceId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // System Configurations & Resources
    match /system/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Global Access for Admins & Fallback Deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // Reports & Moderation
    match /reports/{reportId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
    
    match /message_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }
    
    match /story_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Verification Requests
    match /verification_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Announcements
    match /announcements/{id} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Notification Queue
    match /notification_queue/{id} {
      allow read, write: if isAdmin();
    }

    // Support Tickets
    match /support_tickets/{id} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }
  }
}
